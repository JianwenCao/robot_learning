+ROBOT_PART_COLORS = (
+    (0.92, 0.92, 0.86),  # warm white
+    (0.12, 0.12, 0.12),  # black
+    (0.38, 0.40, 0.42),  # dark gray
+    (0.72, 0.72, 0.68),  # light gray
+    (0.00, 0.62, 0.72),  # cyan/teal
